# Copy this file to .env.local and edit the values for your machine.

# Use local whisper.cpp by default. Use "api" for OpenAI hosted transcription.
TRANSCRIPTION_BACKEND=local

# Local whisper.cpp settings. Run scripts/setup-local-whisper.ps1 on Windows
# to download whisper.cpp and create .env.local automatically.
WHISPER_CPP_BINARY=D:\WhisperLocal\whisper.cpp\Release\whisper-cli.exe
WHISPER_MODEL_PATH=D:\WhisperLocal\models\ggml-base.en.bin

# Server settings.
PORT=8080
MAX_UPLOAD_BYTES=26214400
REQUEST_TIMEOUT_SECONDS=300

# API mode settings. Required only when TRANSCRIPTION_BACKEND=api or when
# requests use backend=api.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
TRANSCRIPTION_MODEL=whisper-1
